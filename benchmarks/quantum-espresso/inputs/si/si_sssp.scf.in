&CONTROL
    calculation = 'vc-relax'
    prefix      = 'si'
    outdir      = './tmp'
    pseudo_dir  = './SSSP_1.3.0_PBE_efficiency'
    verbosity   = 'high'
    etot_conv_thr = 1.0d-6
    forc_conv_thr = 1.0d-4
/

&SYSTEM
    ibrav = 2,
    celldm(1) = 10.26,
    nat = 2,
    ntyp = 1,

    input_dft = 'PBE',

    ecutwfc = 80.0,
    ecutrho = 640.0,

    occupations = 'smearing',
    smearing = 'mv',
    degauss = 0.01
/

&ELECTRONS
    conv_thr = 1.0d-10
    mixing_beta = 0.3
/

&IONS
    ion_dynamics = 'bfgs'
/

&CELL
    cell_dynamics = 'bfgs'
/

ATOMIC_SPECIES
 Si 28.0855 Si.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25

K_POINTS automatic
 12 12 12 0 0 0